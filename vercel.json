{
  "framework": "nextjs",
  "functions": {
    "pages/api/upload.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "pages/api/raw/[slug].ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
