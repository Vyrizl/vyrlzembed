# ── Neon Database ─────────────────────────────────────────────
# Get from: Neon dashboard → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── App URL ───────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ── Session Secret ────────────────────────────────────────────
# Long random string (32+ chars). Signs session tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Setup Secret ──────────────────────────────────────────────
# Protects the one-time /api/setup endpoint. Change this.
SETUP_SECRET=another-random-string-for-setup
